# ═══════════════════════════════════════════════════════════
#  local-agent — .env.example
#  Bu dosyayı .env olarak kopyalayıp kendi değerlerinizi girin:
#    cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ── Ollama / LLM ─────────────────────────────────────────
# Ollama'nın çalıştığı adres (Docker içinde farklı olabilir)
OLLAMA_BASE_URL=http://localhost:11434

# Ana orkestratör model — 7B/14B/32B'ye geçmek için sadece burası değişir
OLLAMA_MODEL=qwen2.5:3b-instruct

# Görsel açıklama için vision model
OLLAMA_VISION_MODEL=qwen2-vl

# Ollama API zaman aşımı (saniye)
OLLAMA_TIMEOUT=120

# ── Güvenlik / Auth ───────────────────────────────────────
# ⚠️  FAZ 1 GEÇİCİ AUTH — Tüm API istekleri X-API-Key header'ı ile yapılır.
# Production ortamında JWT tabanlı auth ile değiştirilmelidir.
# Güçlü, rastgele bir değer kullanın (örn: openssl rand -hex 32)
API_KEY=dev-api-key-change-in-production

# ── Dosya Sistemi Sandbox ─────────────────────────────────
# Dosya işlemleri YALNIZCA bu dizin altında yapılabilir.
# Bu dizin dışına çıkma girişimleri (../../etc/passwd) reddedilir.
# Mutlak path veya backend/ dizinine göreli path verilebilir.
SANDBOX_ROOT=./sandbox

# ── Veritabanı ────────────────────────────────────────────
# SQLite (geliştirme):
DATABASE_URL=sqlite:///./local_agent.db
# PostgreSQL (ileri faz):
# DATABASE_URL=postgresql://user:password@localhost:5432/local_agent

# ── Loglama ───────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log

# ── Agent Davranışı ───────────────────────────────────────
MAX_TOOL_RETRIES=2
CONVERSATION_HISTORY_LIMIT=20
MAX_TOOLS_PER_CATEGORY=8

# ── Sunucu ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ⚠️  FAZ 1 KISITI — in-memory onay/hafıza nedeniyle 1'den fazla worker KULLANMAYIN.
# Redis/DB entegrasyonu tamamlanana kadar bu değer 1 kalmalıdır.
WORKERS=1
DEBUG=false

# ── GitHub & Kod Yönetimi (Faz 3) ─────────────────────────
# GitHub Entegrasyonu
GITHUB_TOKEN=your_github_token_here

# n8n Entegrasyonu
N8N_WEBHOOK_URL=http://localhost:5678/webhook/agent
N8N_API_KEY=your_secure_api_key_here

# Git İşlemleri için İzin Verilen Repolar (Virgülle ayrılmış yollar)
ALLOWED_REPOS=./sandbox/demo-repo,./sandbox/another-repo
